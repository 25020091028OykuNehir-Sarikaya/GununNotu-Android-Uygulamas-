<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#474747"
    tools:context=".DetailActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="144dp"
        android:layout_marginEnd="1dp"
        android:layout_marginBottom="70dp"
        android:text="Günün Notu"
        android:textSize="28sp"
        app:layout_constraintBottom_toTopOf="@+id/textViewNotGoster"
        app:layout_constraintEnd_toEndOf="@+id/textViewNotGoster"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewNotGoster"
        android:layout_width="191dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="73dp"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/buttonGeriDon"
        app:layout_constraintStart_toStartOf="@+id/buttonGeriDon"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <Button
        android:id="@+id/buttonGeriDon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="67dp"
        android:layout_marginBottom="322dp"
        android:backgroundTint="#424243"
        android:text=" Yeni not yaz"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewNotGoster" />
</androidx.constraintlayout.widget.ConstraintLayout>